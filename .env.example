# Copy this file to .env and fill in the values before running the application.
# .env is excluded from version control – never commit real secrets.

# PostgreSQL
POSTGRES_DB=route_planner
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spring Boot datasource (overrides application.yaml defaults)
DB_URL=jdbc:postgresql://localhost:5432/route_planner
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT – MUST be changed to a strong random secret (min 32 chars) in any non-local environment
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRATION=3600000
